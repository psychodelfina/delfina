---
import { Seo } from 'astro-seo-meta';
import { Schema } from 'astro-seo-schema';
import { siteConfig, generateStructuredData } from '../config/site.config';
import Navbar from '../components/Navbar.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const { seo } = siteConfig;

const { 
  title = seo.title, 
  description = seo.description,
  ogImage = seo.ogImage,
  canonicalUrl = seo.siteUrl,
} = Astro.props;

// Generate full URLs
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${seo.siteUrl}${ogImage}`;
const fullCanonicalUrl = canonicalUrl.startsWith('http') ? canonicalUrl : `${seo.siteUrl}${canonicalUrl}`;

// Generate structured data using existing function
const structuredData = generateStructuredData(siteConfig);
---

<!doctype html>
<html lang="ru" class="scroll-smooth">
	<head>
		<!-- Primary Meta Tags (via astro-seo-meta) -->
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta http-equiv="X-UA-Compatible" content="IE=edge" />
		
		<!-- SEO Component - generates title, description, OG, Twitter tags -->
		<Seo
			title={title}
			description={description}
			keywords={seo.keywords}
			author={seo.author}
			canonical={fullCanonicalUrl}
			openGraph={{
				type: seo.ogType,
				url: fullCanonicalUrl,
				title: title,
				description: description,
				image: fullOgImage,
				site_name: seo.siteName,
				locale: seo.locale,
			}}
			twitter={{
				card: seo.twitterCard,
				site: seo.twitterSite,
				image: fullOgImage,
			}}
		/>
		
		<!-- Additional meta from config -->
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content={`${seo.robots.index ? 'index' : 'noindex'}, ${seo.robots.follow ? 'follow' : 'nofollow'}`} />
		{seo.robots.googleBot && <meta name="googlebot" content={seo.robots.googleBot} />}
		
		<!-- Open Graph additional tags -->
		<meta property="og:image:alt" content={seo.ogImageAlt} />
		<meta property="og:image:width" content={String(seo.ogImageWidth)} />
		<meta property="og:image:height" content={String(seo.ogImageHeight)} />
		
		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon.svg" />
		
		<!-- Theme Color -->
		<meta name="theme-color" content={seo.themeColor} />
		<meta name="msapplication-TileColor" content={seo.themeColor} />
		
		<!-- Additional Mobile meta -->
		<meta name="format-detection" content="telephone=no" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content={seo.siteName} />
		
		<!-- Geo Tags -->
		<meta name="geo.region" content="RU-SPE" />
		<meta name="geo.placename" content="Санкт-Петербург" />
		{seo.structuredData.geo && (
			<meta name="geo.position" content={`${seo.structuredData.geo.latitude};${seo.structuredData.geo.longitude}`} />
		)}
		<meta name="ICBM" content={seo.structuredData.geo ? `${seo.structuredData.geo.latitude}, ${seo.structuredData.geo.longitude}` : ''} />
		
		<!-- Language -->
		<link rel="alternate" hreflang="ru" href={seo.siteUrl} />
		<link rel="alternate" hreflang="x-default" href={seo.siteUrl} />
		
		<!-- Sitemap -->
		<link rel="sitemap" type="application/xml" href="/sitemap.xml" />
		
		<!-- Structured Data / JSON-LD (via astro-seo-schema) -->
		<Schema item={structuredData} />
		
		<!-- DNS Prefetch for external resources -->
		<link rel="dns-prefetch" href="https://vk.com" />
		<link rel="dns-prefetch" href="https://www.tiktok.com" />
	</head>
	<body class="font-body bg-bg-dark text-white leading-relaxed">
		<div
			data-scroll-progress
			class="fixed top-0 left-0 h-[3px] w-full z-[1001] origin-left"
			style="transform: scaleX(0); will-change: transform; background: linear-gradient(90deg, #ff2d95 0%, #e930ff 40%, #9945ff 70%, #00d9ff 100%)"
		/>
		<Navbar config={siteConfig} />
		<div class="overflow-x-hidden">
			<slot />
		</div>
	</body>
</html>

<style is:global>
	/* Custom scrollbar */
	::-webkit-scrollbar {
		width: 8px;
	}

	::-webkit-scrollbar-track {
		background: #0a0612;
	}

	::-webkit-scrollbar-thumb {
		background: linear-gradient(135deg, #ff2d95 0%, #e930ff 50%, #9945ff 100%);
		border-radius: 4px;
	}

	/* Selection */
	::selection {
		background: #ff2d95;
		color: white;
	}

	/* Smooth anchor scrolling */
	html {
		scroll-behavior: smooth;
	}

	/* Navbar scroll state */
	#main-nav {
		transition: background 0.3s ease, box-shadow 0.3s ease;
	}
	#main-nav.nav-scrolled {
		background: rgba(10, 6, 18, 0.95);
		box-shadow: 0 4px 30px rgba(255, 45, 149, 0.1);
	}

	/* Hide default details marker in WebKit browsers */
	summary::-webkit-details-marker {
		display: none;
	}
</style>
