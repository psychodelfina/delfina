---
interface Props {
  images: { src: string; alt: string }[];
}

const { images } = Astro.props;
---

<section class="py-24 relative z-[1]" id="portfolio" aria-labelledby="portfolio-heading">
  <div class="max-w-[1200px] mx-auto px-6">
    <h2 id="portfolio-heading" class="font-heading text-3xl md:text-4xl text-center mb-4 flex items-center justify-center gap-4" data-scroll-heading>
      <span class="text-3xl" aria-hidden="true">🎨</span>
      Мои работы
    </h2>
    <p class="text-center text-text-muted text-lg mb-16" data-scroll-subtitle>Яркие татуировки, которые расскажут вашу историю</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" role="list" aria-label="Галерея работ">
      {images.map((image, index) => (
        <figure
          class="portfolio-item relative rounded-2xl overflow-hidden aspect-square cursor-pointer group m-0"
          data-scroll-portfolio
          role="listitem"
          itemscope
          itemtype="https://schema.org/ImageObject"
        >
          <img
            src={image.src}
            alt={image.alt}
            loading="lazy"
            decoding="async"
            class="parallax-gallery w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            data-parallax-speed="0.05"
            itemprop="contentUrl"
            width="400"
            height="400"
          />
          <meta itemprop="name" content={image.alt} />
        </figure>
      ))}
    </div>
  </div>
</section>
