---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  images: { src: string; alt: string }[];
}

const { images } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>('../assets/content/portfolio/*.jpg', { eager: true });

function getImage(filename: string): ImageMetadata | undefined {
  const key = Object.keys(allImages).find(k => k.endsWith(`/${filename}`));
  return key ? allImages[key].default : undefined;
}
---

<section class="relative z-[1]" id="portfolio" aria-labelledby="portfolio-heading">
  <div class="py-24 md:py-0 md:h-screen md:overflow-hidden" data-horizontal-scroll>
    <div class="max-w-[1200px] md:max-w-none mx-auto px-6 md:px-12 md:h-full md:flex md:flex-col md:justify-center">
      <h2 id="portfolio-heading" class="font-heading text-3xl md:text-4xl text-center mb-4 flex items-center justify-center gap-4" data-scroll-heading>
        <span class="text-3xl" aria-hidden="true">🎨</span>
        Мои работы
      </h2>
      <p class="text-center text-text-muted text-lg mb-16 md:mb-8" data-scroll-subtitle>Яркие татуировки, которые расскажут вашу историю</p>

      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:flex md:flex-nowrap md:gap-8"
        data-horizontal-track
        role="list"
        aria-label="Галерея работ"
      >
        {images.map((image) => {
          const filename = image.src.split('/').pop()!;
          const imgData = getImage(filename);
          return imgData && (
            <figure
              class="portfolio-item relative rounded-2xl overflow-hidden aspect-square cursor-pointer group m-0 md:w-[750px] md:flex-shrink-0"
              data-scroll-portfolio
              role="listitem"
              itemscope
              itemtype="https://schema.org/ImageObject"
            >
              <Image
                src={imgData}
                alt={image.alt}
                loading="lazy"
                decoding="async"
                class="parallax-gallery w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                data-parallax-speed="0.05"
                itemprop="contentUrl"
                width={750}
                height={750}
              />
              <meta itemprop="name" content={image.alt} />
            </figure>
          );
        })}
      </div>
    </div>
  </div>
</section>
