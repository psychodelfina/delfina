---
import type { SiteConfig } from '../config/site.config';
import TelegramIcon from './icons/TelegramIcon.astro';
import InstagramIcon from './icons/InstagramIcon.astro';
import VKIcon from './icons/VKIcon.astro';
import TikTokIcon from './icons/TikTokIcon.astro';

interface Props {
  config: SiteConfig;
}

const { config } = Astro.props;
const { contacts } = config;

const vkShortName = new URL(contacts.vk).pathname.replace('/', '');
const tiktokUsername = new URL(contacts.tiktok).pathname.replace('/@', '').replace('/', '');
const telegramUsername = new URL(contacts.telegram).pathname.replace('/', '');

const socials = [
  {
    name: 'Instagram',
    icon: 'instagram',
    url: contacts.instagram,
    handle: '@psychodelfina',
    bg: 'bg-instagram',
    shadow: 'hover:shadow-[0_20px_40px_rgba(225,48,108,0.15)]',
    label: 'Подписаться на Instagram @psychodelfina',
  },
  {
    name: 'ВКонтакте',
    icon: 'vk',
    url: contacts.vk,
    handle: vkShortName,
    bg: 'bg-vk',
    shadow: 'hover:shadow-[0_20px_40px_rgba(0,119,255,0.15)]',
    label: `Подписаться на ВКонтакте ${vkShortName}`,
  },
  {
    name: 'TikTok',
    icon: 'tiktok',
    url: contacts.tiktok,
    handle: `@${tiktokUsername}`,
    bg: 'bg-tiktok',
    shadow: 'hover:shadow-[0_20px_40px_rgba(255,0,80,0.15)]',
    label: `Подписаться на TikTok @${tiktokUsername}`,
  },
  {
    name: 'Telegram',
    icon: 'telegram',
    url: contacts.telegram,
    handle: `@${telegramUsername}`,
    bg: 'bg-telegram',
    shadow: 'hover:shadow-[0_20px_40px_rgba(0,136,204,0.15)]',
    label: `Подписаться на Telegram @${telegramUsername}`,
  },
];
---

<section
  class="py-8 relative z-[1]"
  id="contacts"
  aria-labelledby="contacts-heading"
  style="background: linear-gradient(180deg, transparent 0%, rgba(153, 69, 255, 0.05) 50%, transparent 100%)"
>
  <div class="max-w-[1200px] mx-auto px-6">
    <h2 id="contacts-heading" class="font-heading text-3xl md:text-4xl text-center mb-4 flex items-center justify-center gap-4" data-scroll-heading>
      <span class="text-3xl" aria-hidden="true">📱</span>
      Контакты
    </h2>
    <p class="text-center text-text-muted text-lg mb-16" data-scroll-subtitle>Найдите меня в социальных сетях</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16 items-start max-w-[500px] md:max-w-none mx-auto">
      {socials.map((s) => (
        <div class={`bg-bg-card rounded-3xl p-6 border border-white/10 hover:-translate-y-1 ${s.shadow} transition-all duration-300`} data-scroll-contact>
          <div class="flex items-center gap-3 mb-5 font-semibold text-lg">
            {s.icon === 'instagram' && <InstagramIcon size={32} />}
            {s.icon === 'vk' && <VKIcon size={32} />}
            {s.icon === 'tiktok' && <TikTokIcon size={32} />}
            {s.icon === 'telegram' && <TelegramIcon size={32} />}
            <span>{s.name}</span>
          </div>
          <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.label} class="block rounded-2xl overflow-hidden">
            <div class={`${s.bg} py-10 px-6 text-center flex flex-col gap-3 hover:opacity-90 transition-opacity`}>
              <span class="text-xl font-bold">{s.handle}</span>
              <span class="text-sm opacity-90">Подписаться →</span>
            </div>
          </a>
        </div>
      ))}
    </div>

    <!-- Main CTA -->
    <div class="flex justify-center">
      <div class="text-center p-10 md:p-16 bg-gradient-to-br from-neon-pink/10 to-neon-purple/10 rounded-[32px] border border-neon-pink/30 max-w-[600px]" data-scroll-cta>
        <h3 class="font-heading text-2xl md:text-3xl mb-4 bg-gradient-neon bg-clip-text text-transparent">
          Готовы к яркой татуировке?
        </h3>
        <p class="text-text-muted text-lg mb-8">Напишите мне в Telegram — обсудим вашу идею и запишемся на сеанс!</p>
        <a
          href={contacts.telegram}
          class="inline-flex items-center justify-center gap-3 px-12 py-5 bg-gradient-neon rounded-full text-xl font-semibold hover:-translate-y-1 hover:shadow-glow-pink transition-all duration-300"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Написать в Telegram для записи на тату"
        >
          <TelegramIcon size={28} />
          Написать в Telegram
        </a>
      </div>
    </div>
  </div>
</section>
