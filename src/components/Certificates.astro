---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  images: { src: string; alt: string }[];
  telegramUrl: string;
}

const { images, telegramUrl } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>('../assets/content/certificates/*.jpg', { eager: true });

function getImage(filename: string): ImageMetadata | undefined {
  const key = Object.keys(allImages).find(k => k.endsWith(`/${filename}`));
  return key ? allImages[key].default : undefined;
}
---

<section class="relative z-[1]" id="certificates">
  <div
    class="py-2 md:py-0 md:h-screen md:overflow-hidden"
    data-horizontal-scroll
    style="background: linear-gradient(180deg, transparent 0%, rgba(255, 45, 149, 0.05) 50%, transparent 100%)"
  >
    <div class="max-w-[1200px] md:max-w-none mx-auto px-6 md:px-12 md:h-full md:flex md:flex-col md:justify-center">
      <h2 class="font-heading text-3xl md:text-4xl text-center mb-4 flex items-center justify-center gap-4" data-scroll-heading>
        <span class="text-3xl">🎁</span>
        Подарочные сертификаты
      </h2>
      <p class="text-center text-text-muted text-lg mb-16 md:mb-8" data-scroll-subtitle>Идеальный подарок для тех, кто мечтает о тату</p>

      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:flex md:flex-nowrap md:gap-8"
        data-horizontal-track
      >
        {images.map((image) => {
          const filename = image.src.split('/').pop()!;
          const imgData = getImage(filename);
          return imgData && (
            <div
              class="certificate-item cursor-pointer rounded-2xl overflow-hidden aspect-square md:w-[750px] md:flex-shrink-0 hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(255,45,149,0.2)] transition-all duration-300"
              data-scroll-cert
            >
              <Image
                src={imgData}
                alt={image.alt}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover"
                width={750}
                height={750}
              />
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <div class="max-w-[1200px] mx-auto px-6 py-16">
    <div class="text-center p-10 bg-bg-card rounded-3xl border border-neon-pink/20" data-scroll-cert-cta>
      <p class="text-xl text-text-muted mb-6">Хотите подарить тату? Напишите мне для оформления сертификата!</p>
      <a
        href={telegramUrl}
        class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-gradient-neon rounded-full text-base font-semibold hover:-translate-y-1 hover:shadow-glow-pink transition-all duration-300"
        target="_blank"
        rel="noopener"
      >
        Заказать сертификат
      </a>
    </div>
  </div>
</section>
