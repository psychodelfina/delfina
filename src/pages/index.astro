---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/site.config';

import Hero from '../components/Hero.astro';
import Portfolio from '../components/Portfolio.astro';
import Certificates from '../components/Certificates.astro';
import FAQ from '../components/FAQ.astro';
import Contacts from '../components/Contacts.astro';
import Footer from '../components/Footer.astro';

import ParallaxBackground from '../components/ParallaxBackground';
import Lightbox from '../components/Lightbox';
import PixelBunny from '../components/PixelBunny';
import ScrollAnimations from '../components/ScrollAnimations';
---

<Layout title={siteConfig.seo.title} description={siteConfig.seo.description}>
	<PixelBunny client:load />
	<ParallaxBackground client:load />
	<Hero config={siteConfig}  client:load />
	<Portfolio images={siteConfig.portfolio}  client:load />
	<Certificates images={siteConfig.certificates} telegramUrl={siteConfig.contacts.telegram}  client:load />
	<FAQ items={siteConfig.faq}  client:load />
	<Contacts config={siteConfig}  client:load />
	<Footer config={siteConfig}  client:load />
	<Lightbox client:load />
	<ScrollAnimations client:load />
</Layout>
